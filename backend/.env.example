# Copy this file to .env and fill in your values
# Generate SECRET_KEY with: python -c "import secrets; print(secrets.token_hex(32))"

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=Invoice API
# Used to build the payment page URL sent to customers, e.g. https://yourdomain.com/pay/{id}
APP_URL=http://localhost:8000
ENVIRONMENT=development             # development | production

# ── Email — SendGrid ──────────────────────────────────────────────────────────
# Sign up free at sendgrid.com, create an API key, verify your sender email
SENDGRID_API_KEY=SG.xxxxxxxxxxxx
FROM_EMAIL=invoices@yourdomain.com
FROM_NAME=Your Business Name
ADMIN_EMAIL=you@yourdomain.com      # receives plan upgrade requests

# ── Redis — Upstash (serverless Redis via REST) ───────────────────────────────
# Sign up free at upstash.com → create a Redis database → copy REST URL + token
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── Plan limits ───────────────────────────────────────────────────────────────
FREE_INVOICE_LIMIT=5                # invoices per month on free plan
