generated/
tmp/
temp/

# Compiled/minified output (if a build step is added later)
app/static/dist/
app/static/build/
*.min.js.map
*.min.css.map

# ── IDEs ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
