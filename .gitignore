yarn-error.log*

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
venv/
.venv/
env/
.env/
ENV/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/
wheels/

# Testing
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.lcov

# Type checking & linting
.mypy_cache/
.ruff_cache/
.dmypy.json

# ── Alembic ───────────────────────────────────────────────────────────────────
# Keep migration files — they are source code
# Only ignore the compiled cache inside versions
alembic/versions/__pycache__/

# ── Celery ────────────────────────────────────────────────────────────────────
celerybeat-schedule
celerybeat.pid

# ── Database ──────────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
log/

# ── Generated files ───────────────────────────────────────────────────────────
